# 回响 · 解析+ASR 测评 —— 复制成 eval/.env 再填

# ── 火山豆包 ASR（必填，视频转文字）──────────────────────
# 新版控制台：只需一个 API Key
VOLC_ASR_API_KEY=
# 旧版控制台：用下面两个（二选一，不要和上面同时填）
# VOLC_ASR_APP_KEY=
# VOLC_ASR_ACCESS_KEY=

# ── 抖音解析 sidecar（解析抖音链接必需；只测直链可不填）──────
# 自部署 wujunwei928/parse-video，默认本机 8080
PARSE_VIDEO_API_URL=http://localhost:8080

# ── 本机 ffmpeg（抽音频）─────────────────────────────────
# 已加进 PATH 就留 ffmpeg；否则填完整路径，如 C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=ffmpeg

# ── 其它（可选）──────────────────────────────────────────
PORT=6060
MAX_UPLOAD_MB=200
